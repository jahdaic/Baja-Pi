#!/usr/bin/env bash
#
# Launch the Baja dashboard in Chromium kiosk mode on the local display.
#
# Designed to run as a pm2-supervised process: it waits for the X server and
# the UI server to come up (so it survives the boot race where pm2 resurrects
# before the desktop is ready), then exec's Chromium in the foreground so pm2
# owns the process directly.
#
set -uo pipefail

export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

URL="${KIOSK_URL:-http://localhost:5173/}"
PROFILE="${KIOSK_PROFILE:-$HOME/.local/share/baja-kiosk}"

log() { printf '[chromium-kiosk] %s\n' "$*"; }

# 1. Wait for the X server to accept connections (up to ~60s).
log "waiting for X on $DISPLAY ..."
for _ in $(seq 1 60); do
	xset q >/dev/null 2>&1 && break
	sleep 1
done
xset q >/dev/null 2>&1 || { log "X server not reachable on $DISPLAY, giving up (pm2 will retry)"; exit 1; }

# 2. Wait for the UI server to answer (up to ~120s).
log "waiting for UI at $URL ..."
for _ in $(seq 1 120); do
	curl -sf -o /dev/null "$URL" && break
	sleep 1
done
curl -sf -o /dev/null "$URL" || { log "UI not reachable at $URL, giving up (pm2 will retry)"; exit 1; }

# 3. Clear any "Chromium didn't shut down correctly" restore prompt from a
#    previous hard kill, so the kiosk never shows the restore bubble.
PREFS="$PROFILE/Default/Preferences"
if [ -f "$PREFS" ]; then
	sed -i 's/"exit_type":"[^"]*"/"exit_type":"Normal"/' "$PREFS" 2>/dev/null || true
fi

log "launching Chromium kiosk -> $URL"
exec chromium \
	--kiosk \
	--user-data-dir="$PROFILE" \
	--no-first-run \
	--noerrdialogs \
	--disable-infobars \
	--disable-translate \
	--disable-session-crashed-bubble \
	--disable-features=TranslateUI \
	--overscroll-history-navigation=0 \
	--check-for-update-interval=31536000 \
	--autoplay-policy=no-user-gesture-required \
	"$URL"
