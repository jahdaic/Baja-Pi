# Baja Dashboard - environment configuration
#
# Copy this file to `.env` in this same directory (UI/) and adjust the values.
# Vite reads these at build/dev start; every variable MUST be prefixed with VITE_.
# `.env` is git-ignored. Note that any VITE_* value is bundled into the client
# code, so do NOT store real secrets here.

# --- App ----------------------------------------------------------------------

# URL of the GPS HTTP server (the pm2 `gps-server`, which bridges gpsd).
VITE_GPSD_SERVER_URL=http://orangepi.local:8000

# Deprecated: weather now uses the keyless NWS + Open-Meteo APIs, so no key is
# required. Kept for reference only; leave blank.
VITE_OPEN_WEATHER_API_KEY=

# --- Gauges -------------------------------------------------------------------

# Top of the speedometer dial, in mph.
VITE_SPEED_LIMIT=80

# The analog sensor gauges are (to be) driven by an ADC voltage reading.
# For each gauge:
#   *_MIN_VOLTAGE / *_MAX_VOLTAGE - the sensor's output voltage range
#   *_LIMIT                       - top of the gauge dial
#   *_REDLINE / *_RESERVE         - warning threshold
# (The voltage->value scaling these imply is planned, not yet implemented.)

# Tachometer (RPM)
VITE_RPM_MIN_VOLTAGE=0
VITE_RPM_MAX_VOLTAGE=5
VITE_RPM_LIMIT=7000
VITE_RPM_REDLINE=5000

# Fuel level (%) - RESERVE is the low-fuel warning point
VITE_FUEL_MIN_VOLTAGE=0
VITE_FUEL_MAX_VOLTAGE=5
VITE_FUEL_RESERVE=0

# Oil temperature (deg F)
VITE_OIL_TEMP_MIN_VOLTAGE=0
VITE_OIL_TEMP_MAX_VOLTAGE=5
VITE_OIL_TEMP_REDLINE=225
VITE_OIL_TEMP_LIMIT=300

# Oil pressure (PSI)
VITE_OIL_PRESSURE_MIN_VOLTAGE=0
VITE_OIL_PRESSURE_MAX_VOLTAGE=5
VITE_OIL_PRESSURE_REDLINE=3
VITE_OIL_PRESSURE_LIMIT=70

# System voltage (V) - REDLINE is the low-voltage warning point
VITE_VOLTAGE_MIN_VOLTAGE=0
VITE_VOLTAGE_MAX_VOLTAGE=5
VITE_VOLTAGE_REDLINE=9
VITE_VOLTAGE_LIMIT=14
